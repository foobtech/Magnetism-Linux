# This file provides configuration information for OpenSSL
prefix=/usr/local
exec_prefix=${prefix}
libdir=${exec_prefix}/lib64
includedir=${prefix}/include
modulesdir=${libdir}/ossl-modules

Name: OpenSSL-libcrypto
Description: OpenSSL cryptography library
Version: 4.1.0-dev
Libs: -L${libdir} -lcrypto
Libs.private: -ldl -pthread -lssl_a -lcrypto_a
Cflags: -I${includedir}
